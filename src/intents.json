{
    "help": {
      "patterns": [
        "(?i)\\bпомощ\\b",
        "(?i)\\bhelp\\b",
        "(?i)\\bпомогни\\b"
      ],
      "response": "Клубове: Добави клуб <Име>, Покажи всички клубове, Изтрий клуб <Име>\nИграчи: Добави играч <име> в клуб <клуб> позиция <GK|DF|MF|FW> номер <1-99>, Покажи всички играчи, Покажи играчи на клуб <клуб>, Смени номер на <име> на <номер>, Смени статус на <име> на <active|injured|retired>, Изтрий играч <име>\nТрансфери: Трансфер <име> от <клуб> в <клуб> <YYYY-MM-DD> [сума <сума>], Покажи трансфери на <име>, Покажи трансфери на клуб <клуб>\nЛиги: Създай лига <име> <сезон>, Добави отбор <клуб> в лига <име> <сезон>, Премахни отбор <клуб> от лига <име> <сезон>, Покажи отбори в лига <име> <сезон>, Генерирай програма <име> <сезон>, Покажи програма <име> <сезон>, Изтрий лига <име> <сезон>\nСистема: помощ, изход"
    },
    "exit": {
      "patterns": [
        "(?i)\\bизход\\b",
        "(?i)\\bexit\\b",
        "(?i)\\bquit\\b"
      ],
      "response": "Довиждане!"
    },
    "add_club": {
      "patterns": [
        "(?i)\\bдобави (?:клуб )?(?P<name>.+)",
        "(?i)\\bдобави_клуб (?P<name>.+)",
        "(?i)\\badd club (?P<name>.+)"
      ],
      "response": "Attempting to add club..."
    },
    "list_clubs": {
      "patterns": [
        "(?i)\\bпокажи (?:всички )?клубове\\b",
        "(?i)\\bсписък (?:на )?клубовете\\b",
        "(?i)\\blist clubs\\b"
      ],
      "response": "Listing clubs..."
    },
    "delete_club": {
      "patterns": [
        "(?i)\\bизтрий клуб (?P<name>.+)",
        "(?i)\\bпремахни клуб (?P<name>.+)",
        "(?i)\\bdelete club (?P<name>.+)"
      ],
      "response": "Attempting to delete club..."
    },
    "add_player": {
      "patterns": [
        "(?i)добави играч (?P<name>.+) в клуб (?P<club>.+) на позиция (?P<position>GK|DF|MF|FW) с номер (?P<number>\\d+) и националност (?P<nationality>.+) и дата на раждане (?P<birth_date>\\d{4}-\\d{2}-\\d{2}) и статус (?P<status>active|injured|retired)",
        "(?i)добави играч (?P<name>.+) в (?P<club>.+) позиция (?P<position>GK|DF|MF|FW) номер (?P<number>\\d+)"
      ],
      "response": "Attempting to add player..."
    },
    "list_players": {
      "patterns": [
        "(?i)покажи всички играчи",
        "(?i)покажи играчи на клуб (?P<club>.+)"
      ],
      "response": "Listing players..."
    },
    "update_player_number": {
      "patterns": [
        "(?i)смени номер на (?P<name>.+) на (?P<number>\\d+)"
      ],
      "response": "Updating player number..."
    },
    "update_player_status": {
      "patterns": [
        "(?i)смени статус на (?P<name>.+) на (?P<status>active|injured|retired)"
      ],
      "response": "Updating player status..."
    },
    "delete_player": {
      "patterns": [
        "(?i)изтрий играч (?P<name>.+)"
      ],
      "response": "Deleting player..."
    },
    "transfer_player": {
      "patterns": [
        "(?i)трансфер (?P<player>.+) от (?P<from_club>.+) в (?P<to_club>.+) (?P<date>\\d{4}-\\d{2}-\\d{2})(?:\\s+сума\\s+(?P<fee>\\d+))?",
        "(?i)трансферирай (?P<player>.+) от (?P<from_club>.+) в (?P<to_club>.+) (?P<date>\\d{4}-\\d{2}-\\d{2})(?:\\s+сума\\s+(?P<fee>\\d+))?"
      ],
      "response": "Processing transfer..."
    },
    "show_transfers_club": {
      "patterns": [
        "(?i)^покажи трансфери на клуб (?P<club>.+)",
        "(?i)^трансфери на клуб (?P<club>.+)",
        "(?i)покажи трансфери на клуб (?P<club>.+)",
        "(?i)трансфери на клуб (?P<club>.+)"
      ],
      "response": "Showing club transfers..."
    },
    "show_transfers_player": {
      "patterns": [
        "(?i)^покажи трансфери на (?P<player>.+)",
        "(?i)^трансфери на (?P<player>.+)",
        "(?i)покажи трансфери на (?P<player>.+)",
        "(?i)трансфери на (?P<player>.+)"
      ],
      "response": "Showing player transfers..."
    },
    "create_league": {
      "patterns": [
        "(?i)^създай лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^създай лига (?P<name>.+?) (?P<season>\\d{4}-\\d{4})$"
      ],
      "response": "Creating league..."
    },
    "add_team_to_league": {
      "patterns": [
        "(?i)^добави отбор (?P<club>.+?) в лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^добави клуб (?P<club>.+?) в лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$"
      ],
      "response": "Adding team to league..."
    },
    "remove_team_from_league": {
      "patterns": [
        "(?i)^премахни отбор (?P<club>.+?) от лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^премахни клуб (?P<club>.+?) от лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$"
      ],
      "response": "Removing team from league..."
    },
    "show_teams_in_league": {
      "patterns": [
        "(?i)^покажи отбори в лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^покажи клубове в лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^отбори в лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$"
      ],
      "response": "Showing teams in league..."
    },
    "generate_schedule": {
      "patterns": [
        "(?i)^генерирай програма (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^генерирай програма за (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^създай програма (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$"
      ],
      "response": "Generating schedule..."
    },
    "show_schedule": {
      "patterns": [
        "(?i)^покажи програма (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^програма (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$",
        "(?i)^покажи мачове (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$"
      ],
      "response": "Showing schedule..."
    },
    "delete_league": {
      "patterns": [
        "(?i)^изтрий лига (?P<name>.+?) (?P<season>\\d{4}/\\d{4})$"
      ],
      "response": "Deleting league..."
    }
  }
